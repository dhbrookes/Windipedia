# ============================================================
# Windipedia — environment variable reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# -----------------------------------------------------------
# Frontend (Vite)
# Vite exposes variables prefixed with VITE_ to the browser.
# -----------------------------------------------------------

# Mapbox GL JS public token.
# Get yours at: https://account.mapbox.com/access-tokens/
# The default public token scope is sufficient for tile rendering.
VITE_MAPBOX_TOKEN=pk.eyJ1IjoieW91ci11c2VybmFtZSIsImEiOiJjbGFzc2lmb...

# Backend API base URL (used by the frontend to construct tile URLs).
# In local dev this is proxied by Vite; in production set to your Cloud Run URL.
VITE_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------
# Backend (FastAPI)
# -----------------------------------------------------------

# GCS bucket used to cache computed tiles (no gs:// prefix).
# Tiles are computed on-demand from Zarr and cached here as:
#   cache/{md5_hash}.png
# ERA5 data never changes so cached tiles never expire.
TILE_CACHE_BUCKET=windipedia-tile-cache

# Full path to the ERA5 ARCO Zarr store.
# The default is the public GCP bucket — no auth needed for reads.
ERA5_ZARR_PATH=gs://gcp-public-data-arco-era5/ar/full_37-1h-0p25deg-chunk-1.zarr-v3

# GCP region where this backend runs.
# Set to us-central1 to colocate with the ERA5 bucket — avoids egress costs
# and reduces tile compute latency from ~60 s to ~10 s.
GCP_REGION=us-central1

# Set to "true" to return a transparent placeholder tile for every request
# without touching GCS or xarray. Useful for frontend dev without GCP access.
USE_PLACEHOLDER_TILES=false

# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Deployment environment: "development" | "production"
ENVIRONMENT=development

# -----------------------------------------------------------
# GCP credentials (backend + pipeline)
# -----------------------------------------------------------

# Path to a GCP service account JSON key file.
# Not required if running on GCP with Workload Identity, or if you've
# authenticated locally with: gcloud auth application-default login
# The ERA5 source bucket is public (reads are always unauthenticated).
# Credentials are only needed to write to TILE_CACHE_BUCKET.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# -----------------------------------------------------------
# Development / testing shortcuts
# -----------------------------------------------------------

# Set to "true" to make the backend use a small synthetic ERA5 dataset instead
# of connecting to GCS. Enables running pytest and manual backend testing without
# any GCP credentials or network access.
# WARNING: fake data only — never use in production.
MOCK_ERA5=false

# Set to "true" to make the frontend skip real API calls and use local mock data
# (see frontend/src/mocks/mockApi.js). Useful for UI development without a
# running backend. Tiles show solid-color overlays; distributions are synthetic.
VITE_MOCK_API=true
